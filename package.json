{
  "name": "consentimientos-app",
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "electron:dev": "cross-env NODE_ENV=development electron electron/main.js",
    "electron:build": "ng build && electron electron/main.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
    
  },
  "build": {
    "appId": "com.roook.hourscontrol",
    "productName": "Rook Hours Control",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/main.js",
      "electron/preload.js"
      
    ],
    "win": {
      "target": "nsis",
      "icon": "build/logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/logo.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.1",
    "better-sqlite3": "^12.8.0",
    "express": "^5.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "mammoth": "^1.11.0",
    "pdfmake": "^0.3.7",
    "rxjs": "~7.8.0",
    "signature_pad": "^5.1.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/pdfmake": "^0.3.2",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
